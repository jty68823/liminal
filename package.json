{
  "name": "@liminal/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=!@liminal/desktop",
    "dev:web": "turbo run dev --filter=@liminal/web",
    "dev:api": "turbo run dev --filter=@liminal/api",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "lint": "eslint .",
    "desktop:dev": "pnpm --filter @liminal/desktop dev:electron",
    "desktop:build": "pnpm --filter @liminal/desktop package"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-llama-cpp",
      "electron",
      "@jitsi/robotjs"
    ]
  }
}
