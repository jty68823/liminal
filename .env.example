# Liminal AI Engine (node-llama-cpp)
LIMINAL_DEFAULT_MODEL=Meta-Llama-3.1-8B-Instruct-Q4_K_M
LIMINAL_FAST_MODEL=Meta-Llama-3.1-8B-Instruct-Q4_K_M
LIMINAL_CODE_MODEL=Qwen2.5-Coder-7B-Instruct-Q4_K_M
LIMINAL_EMBED_MODEL=nomic-embed-text-v1.5.Q8_0
LIMINAL_MODELS_DIR=./data/models
LIMINAL_GPU_LAYERS=-1

# Database
DATABASE_PATH=./data/liminal.db

# API Server
API_PORT=3001
API_HOST=0.0.0.0

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# SearXNG (optional web search)
SEARXNG_URL=http://localhost:8080

# Auth (optional)
JWT_SECRET=change-me-in-production
